{
  "manifest_version": 3,
  "name": "Pocket Option OTC Algo Bot",
  "version": "1.0.0",
  "description": "Automated OTC trading signals and execution for Pocket Option demo account",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://pocketoption.com/*",
    "https://po.trade/*",
    "https://api.telegram.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://pocketoption.com/*", "https://po.trade/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OTC Algo Bot"
  }
}
